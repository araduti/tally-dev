{
  "name": "tally",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "^16.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@trpc/server": "^11.1.0",
    "@trpc/client": "^11.1.0",
    "@trpc/react-query": "^11.1.0",
    "@trpc/next": "^11.1.0",
    "@tanstack/react-query": "^5.75.0",
    "better-auth": "^1.6.0",
    "@prisma/client": "^7.7.0",
    "zod": "^3.25.0",
    "decimal.js": "^10.5.0",
    "superjson": "^2.2.2",
    "inngest": "^3.35.0",
    "ioredis": "^5.6.1",
    "@aws-sdk/client-s3": "^3.800.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "prisma": "^7.7.0",
    "eslint": "^9.27.0",
    "eslint-config-next": "^16.2.0",
    "@eslint/eslintrc": "^3.3.1",
    "vitest": "^3.2.1",
    "@playwright/test": "^1.52.0",
    "tsx": "^4.19.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0"
  }
}
